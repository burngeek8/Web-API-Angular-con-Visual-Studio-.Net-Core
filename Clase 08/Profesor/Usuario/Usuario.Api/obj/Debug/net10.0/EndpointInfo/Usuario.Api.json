            "type": "string",
            "nullable": true
          },
          "apellidoMaterno": {
            "type": "string",
            "nullable": true
          },
          "password": {
            "type": "string",
            "nullable": true
          },
          "fechaNacimiento": {
            "type": "string",
            "format": "date-time"
          },
          "correoElectronico": {
            "type": "string",
            "nullable": true
          },
          "pais": {
            "type": "string",
            "nullable": true
          },
          "departamento": {
            "type": "string",
            "nullable": true
          },
          "provincia": {
            "type": "string",
            "nullable": true
          },
          "distrito": {
            "type": "string",
            "nullable": true
          },
          "calle": {
            "type": "string",
            "nullable": true
          },
          "nombreRol": {
            "type": "string",
            "nullable": true
          }
