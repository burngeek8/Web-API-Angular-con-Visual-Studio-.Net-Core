        "required": [
          "nombresPersona",
          "apellidoPaterno",
          "apellidoMaterno",
          "password",
          "fechaNacimiento",
          "correoElectronico",
          "pais",
          "departamento",
          "provincia",
          "distrito",
          "calle",
          "nombreRol"
        ],
        "type": "object",
        "properties": {
          "nombresPersona": {
            "type": "string"
          },
          "apellidoPaterno": {
            "type": "string"
          },
          "apellidoMaterno": {
            "type": [
              "null",
              "string"
            ]
          },
          "password": {
            "type": [
              "null",
              "string"
            ]
          },
          "fechaNacimiento": {
            "type": "string",
            "format": "date-time"
          },
          "correoElectronico": {
            "type": [
              "null",
              "string"
            ]
          },
          "pais": {
            "type": "string"
          },
          "departamento": {
            "type": "string"
          },
          "provincia": {
            "type": "string"
          },
          "distrito": {
            "type": "string"
          },
          "calle": {
            "type": "string"
          },
          "nombreRol": {
            "type": "string"
          }
        }
      },
      "LoginRequest": {
        "required": [
          "nombreUsuario",
          "password"
        ],
        "type": "object",
        "properties": {
          "nombreUsuario": {
            "type": "string"
          },
          "password": {
            "type": "string"
          }
        }
      }
    }
  },
  "tags": [
    {
      "name": "Usuario"
    }
  ]
